# --- Aplicación ---
NODE_ENV=production
PORT=3000
URL=http://localhost:3000
SECRET=topSecret51
CORS=true

# --- Base de datos PostgreSQL ---
TYPE=postgres
SSL=false
DB_NAME=api-navecopa
DB_PORT=5432
DB_HOST=localhost
DB_USER=postgres
DB_PASS=postgres
DB_SYNC=false
DB_MIGRATIONS_RUN=true

# --- Logger ---
LOGGER=true
LOGGER_LEVELS=error,warn,log

# --- Email (opcional) ---
# EMAIL_SMTP=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_ID=your-email@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM=noreply@example.com

# --- Migraciones ---
MIGRATION_PATH=./src/database/migrations
